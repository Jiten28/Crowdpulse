# Copy this file to .env and fill in real values. Never commit .env itself.

# Get a free key at https://aistudio.google.com/apikey — no credit card, no expiration.
GEMINI_API_KEY=
# "gemini-flash-lite-latest" is Google's self-updating alias for the Flash-Lite
# tier, chosen deliberately: the newest flagship Flash models have been
# observed with very tight free-tier daily quotas (as low as 20 requests/day
# on gemini-3.5-flash as of July 2026), while Flash-Lite consistently reports
# a much higher allowance and is well suited to this app's short, structured
# tasks (classification-style risk assessment, brief chat answers).
GEMINI_MODEL=gemini-flash-lite-latest

MAX_UPLOAD_MB=2
RATE_LIMIT_CHAT_PER_MIN=10
# Use * for local development. In production (Render), this is set to the
# actual deployed origin (https://crowdpulse-70bq.onrender.com) directly in
# Render's dashboard / render.yaml — scoping CORS to a real origin instead of
# a wildcard is a genuine security improvement, not just cosmetic.
ALLOWED_ORIGIN=*
INCIDENT_DB_PATH=incidents.db
