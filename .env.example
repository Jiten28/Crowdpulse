# Copy this file to .env and fill in real values. Never commit .env itself.

# Which provider to use: "gemini" (free, no credit card, recommended) or "anthropic" (paid).
LLM_PROVIDER=gemini

# Only needed if LLM_PROVIDER=gemini. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# "gemini-flash-latest" is Google's self-updating alias, not a pinned version.
# Google has been retiring specific dated models early for new API keys in 2026
# (e.g. gemini-2.5-flash returning 404 "no longer available to new users" ahead
# of its official deprecation date). If this alias ever breaks, check
# https://ai.google.dev/gemini-api/docs/models for the current model list.
GEMINI_MODEL=gemini-flash-latest

# Only needed if LLM_PROVIDER=anthropic. Requires a funded account at console.anthropic.com
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

MAX_UPLOAD_MB=2
RATE_LIMIT_CHAT_PER_MIN=10
ALLOWED_ORIGIN=*
INCIDENT_DB_PATH=incidents.db
